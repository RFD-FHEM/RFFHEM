{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "run prove FHEM module tests",
            "type": "shell",
            "command": "FHEM_PROVE_OPTIONS='${input:proveOptions}' bash .devcontainer/scripts/run-selected-tests.sh fhem ${input:dynamicFHEMModuleFilesRemembered}",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": {
                "owner": "TAP",
                "fileLocation": "relative",
                "pattern": [
                    {
                        "regexp": "^#\\s+(Failed test '.*')",
                        "message": 1
                    },
                    {
                        "regexp": "^#\\s+at (.*) line (\\d+)",
                        "line": 2,
                        "file": 1
                    }
                ]
            },
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "run proove all FHEM tests",
            "type": "shell",
            "command": "FHEM_PROVE_OPTIONS='${input:proveOptions}' bash .devcontainer/scripts/run-selected-tests.sh fhem",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": {
                "owner": "TAP",
                "fileLocation": "relative",
                "pattern": [
                    {
                        "regexp": "^#\\s+(Failed test '.*')",
                        "message": 1
                    },
                    {
                        "regexp": "^#\\s+at (.*) line (\\d+)",
                        "line": 2,
                        "file": 1
                    }
                ]
            },
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "run prove Perl module files",
            "type": "shell",
            "command": "FHEM_PROVE_OPTIONS='${input:proveOptions}' bash .devcontainer/scripts/run-selected-tests.sh perl ${input:dynamicPERLModuleFilesRemembered}",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": {
                "owner": "TAP",
                "fileLocation": "relative",
                "pattern": [
                    {
                        "regexp": "^#\\s+(Failed test '.*')",
                        "message": 1
                    },
                    {
                        "regexp": "^#\\s+at (.*) line (\\d+)",
                        "line": 2,
                        "file": 1
                    }
                ]
            },
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "run prove active file FHEM module test",
            "type": "shell",
            "command": "FHEM_PROVE_OPTIONS='${input:proveOptions}' bash .devcontainer/scripts/run-active-test.sh fhem ${file}",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": {
                "owner": "TAP",
                "fileLocation": "relative",
                "pattern": [
                    {
                        "regexp": "^#\\s+(Failed test '.*')",
                        "message": 1
                    },
                    {
                        "regexp": "^#\\s+at (.*) line (\\d+)",
                        "line": 2,
                        "file": 1
                    }
                ]
            },
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "run prove active file Perl module test",
            "type": "shell",
            "command": "FHEM_PROVE_OPTIONS='${input:proveOptions}' bash .devcontainer/scripts/run-active-test.sh perl ${file}",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": {
                "owner": "TAP",
                "fileLocation": "relative",
                "pattern": [
                    {
                        "regexp": "^#\\s+(Failed test '.*')",
                        "message": 1
                    },
                    {
                        "regexp": "^#\\s+at (.*) line (\\d+)",
                        "line": 2,
                        "file": 1
                    }
                ]
            },
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "run SVN checkout",
            "type": "shell",
            "command": "bash .devcontainer/scripts/svn-checkout.sh",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "sync module to SVN",
            "type": "shell",
            "command": "bash .devcontainer/scripts/sync-module-to-svn.sh",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "FHEM: run all tests",
            "type": "shell",
            "command": "FHEM_PROVE_OPTIONS='${input:proveOptions}' bash .devcontainer/scripts/run-all-tests.sh",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": {
                "owner": "TAP",
                "fileLocation": "relative",
                "pattern": [
                    {
                        "regexp": "^#\\s+(Failed test '.*')",
                        "message": 1
                    },
                    {
                        "regexp": "^#\\s+at (.*) line (\\d+)",
                        "line": 2,
                        "file": 1
                    }
                ]
            },
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "FHEM: run single test",
            "type": "shell",
            "command": "FHEM_PROVE_OPTIONS='${input:proveOptions}' bash .devcontainer/scripts/run-single-test.sh ${input:testFile}",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": {
                "owner": "TAP",
                "fileLocation": "relative",
                "pattern": [
                    {
                        "regexp": "^#\\s+(Failed test '.*')",
                        "message": 1
                    },
                    {
                        "regexp": "^#\\s+at (.*) line (\\d+)",
                        "line": 2,
                        "file": 1
                    }
                ]
            },
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "FHEM: pick and run test",
            "type": "shell",
            "command": "bash .devcontainer/scripts/pick-fhem-test.sh",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": {
                "owner": "TAP",
                "fileLocation": "relative",
                "pattern": [
                    {
                        "regexp": "^#\\s+(Failed test '.*')",
                        "message": 1
                    },
                    {
                        "regexp": "^#\\s+at (.*) line (\\d+)",
                        "line": 2,
                        "file": 1
                    }
                ]
            },
            "group": {
                "kind": "test",
                "isDefault": true
            }
        }
    ],
    "inputs":  [
        {
            "id": "testFile",
            "type": "promptString",
            "description": "Path to the .t test file, relative to the repo test root",
            "default": "path/to/test.t"
        },
        {
            "id": "proveOptions",
            "type": "command",
            "command": "extension.commandvariable.pickStringRemember",
            "args": {
                "key": "proveOptions",
                "multiPick" : true,
                "options": [
                        ["verbose", "-v "],
                        ["merge", "-m "],
                        ["parse", "-p" ],
                        ["failures", "-f "],
                        ["formatter TAP", "--formatter TAP"],
                        ["4 parallel jobs", "-j4"],
                        ["8 parallel jobs", "-j8"],
                        ["12 parallel jobs", "-j12"]
                    ],
                "description": "prove Options to activate"
            }
        },
        {
            "id": "dynamicFHEMModuleFilesRemembered",
            "type": "command",
            "command": "extension.commandvariable.pickStringRemember",
            "args": {
                "description": "FHEM module tests",
                "options": [
                    ["Use previous selection", "${remember:FHEMTestFiles}"],
                    ["Pick tests", "${pickFile:FHEMModuleFile}"]
                ],
                "key": "FHEMTestFiles",
                "multiPick": true,
                "rememberTransformed": true,
                "pickFile": {
                    "FHEMModuleFile": {
                        "description": "Which FHEM tests should run?",
                        "include": "t/FHEM/[0-9][0-9]*/**/*.{t}",
                        "multiPick": true,
                        "keyRemember": "FHEMModuleFile"
                    }
                }
            }
        },
        {
            "id": "dynamicPERLModuleFilesRemembered",
            "type": "command",
            "command": "extension.commandvariable.pickStringRemember",
            "args": {
                "description": "Perl module tests",
                "options": [
                    ["Use previous selection", "${remember:PERLTestFiles}"],
                    ["Pick tests", "${pickFile:PERLModuleFile}"]
                ],
                "key": "PERLTestFiles",
                "multiPick": true,
                "rememberTransformed": true,
                "pickFile": {
                    "PERLModuleFile": {
                        "description": "Which Perl tests should run?",
                        "include": "t/**/*.{t}",
                        "exclude": "t/FHEM/[0-9][0-9]*",
                        "multiPick": true,
                        "keyRemember": "PERLModuleFile"
                    }
                }
            }
        }
    ]
}
